{
  "name": "agent-memory-protocol",
  "version": "0.4.0",
  "description": "Agent Memory Protocol - 让每一个 AI Agent 都能快速和便捷的共享相同的记忆",
  "description_en": "Agent Memory Protocol - Enable every AI Agent to share the same memory quickly and conveniently",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "module": "dist/index.js",
  "type": "module",
  "bin": {
    "amp-server": "./mcp/index.ts"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "start": "node --experimental-modules mcp/index.ts",
    "demo": "node demo.js",
    "build": "tsc",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "test:watch": "jest --watch",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "ai",
    "agent",
    "memory",
    "protocol",
    "llm",
    "openai",
    "claude",
    "context",
    "vector",
    "graph",
    "mcp",
    "model-context-protocol",
    "rag",
    "retrieval"
  ],
  "license": "MIT",
  "author": "ai-nurmamat <nurmamat@ozluk.ai>",
  "contributors": [
    "Nurmamat <nurmamat@ozluk.ai>"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/ai-nurmamat/AMP.git"
  },
  "homepage": "https://github.com/ai-nurmamat/AMP#readme",
  "bugs": {
    "url": "https://github.com/ai-nurmamat/AMP/issues",
    "email": "nurmamat@ozluk.ai"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "peerDependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "redis": "^5.11.0",
    "sqlite": "^5.1.1",
    "sqlite3": "^6.0.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@typescript-eslint/eslint-plugin": "^8.58.1",
    "@typescript-eslint/parser": "^8.58.1",
    "eslint": "^10.2.0",
    "jest": "^30.3.0",
    "prettier": "^3.8.1",
    "ts-jest": "^29.4.9",
    "typescript-eslint": "^8.58.2"
  }
}
